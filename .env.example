# Supabase (safe to expose - RLS restricts to read-only)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (NEVER expose - used only in seed script)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps - server-side key (used in Netlify Functions, NOT exposed to browser)
GOOGLE_MAPS_API_KEY=your-server-api-key

# Google Maps - client-side key (referrer-restricted to your domain, Places API only)
PUBLIC_GOOGLE_MAPS_CLIENT_KEY=your-client-api-key
