      <option value="YYZ">Toronto (YYZ)</option>
    </datalist>
  </div>
  <div class="control-group fly-only" style="display:none">
    <label>Max Flight (hrs)</label>
    <input type="number" id="maxFlight" value="6" min="1" max="24">
  </div>

  <div class="control-group">
    <label>&nbsp;</label>
    <button class="btn btn-primary" id="searchBtn">Search</button>
  </div>
  <div class="loading" id="loading">
    <div class="spinner"></div>
    <span id="loadingText">Calculating...</span>
  </div>
</div>

<div class="filters">
  <span class="filter-label">Pass:</span>
  <span class="filter-chip active" data-filter="pass" data-value="all">All</span>
  <span class="filter-chip" data-filter="pass" data-value="Ikon">Ikon</span>
  <span class="filter-chip" data-filter="pass" data-value="Epic">Epic</span>
  <span class="filter-chip" data-filter="pass" data-value="Indy">Indy</span>
  <span class="filter-chip" data-filter="pass" data-value="Mountain Collective">Mountain Collective</span>
  <span class="filter-chip" data-filter="pass" data-value="Club Med">Club Med</span>
  <span style="margin-left: 16px"></span>
  <span class="filter-label">Daycare:</span>
  <span class="filter-chip active" data-filter="daycare" data-value="all">All</span>
  <span class="filter-chip" data-filter="daycare" data-value="yes">Has Daycare</span>
  <span style="margin-left: 16px"></span>
  <span class="filter-label">Kids Free:</span>
  <span class="filter-chip active" data-filter="kidsfree" data-value="all">All</span>
  <span class="filter-chip" data-filter="kidsfree" data-value="yes">Kids Ski Free</span>
</div>

<div class="status-bar" id="statusBar">Choose Drive or Fly, then click Search.</div>

<main>
  <table id="resortTable">
    <thead>
      <tr>
        <th data-col="travelTime">Travel Time <span class="sort-arrow">&#9660;</span></th>
        <th data-col="pass">Pass <span class="sort-arrow">&#9660;</span></th>
        <th data-col="name">Resort <span class="sort-arrow">&#9660;</span></th>
        <th data-col="location">Location <span class="sort-arrow">&#9660;</span></th>
        <th data-col="acreage">Acreage <span class="sort-arrow">&#9660;</span></th>
        <th data-col="kids_ski_free">Kids Free <span class="sort-arrow">&#9660;</span></th>
        <th data-col="ski_school_min_age">Ski School Age <span class="sort-arrow">&#9660;</span></th>
        <th>Ski School Cost</th>
        <th>Daycare</th>
        <th>Local Airport</th>
        <th>Major Airport</th>
      </tr>
    </thead>
    <tbody id="resortBody"></tbody>
  </table>
  <div class="empty" id="emptyState">Choose Drive or Fly above, then click Search.</div>
  <p class="footnote fly-col" style="display:none">Flight times are rough estimates: great-circle distance ÷ 500 mph, plus 1 h taxi/takeoff/descent. Hub-to-hub routes assumed direct; all other routes add a 2 h layover allowance; long hauls (>2,500 mi) add another 30 min. Actual times vary with routing, airline, and connections.</p>
</main>

<script define:vars={{ resorts, airports }}>
  const RESORTS = resorts;
  const AIRPORTS = airports;

  let currentMode = 'drive';
  let currentResults = [];
  let sortCol = 'acreage';
  let sortAsc = true;
  const activeFilters = { pass: 'all', daycare: 'all', kidsfree: 'all' };

  // Parse airport code from text like "Reno (RNO)"
  function parseAirportCode(str) {
    if (!str) return null;
    const match = str.match(/\(([A-Z]{3})\)/);
    return match ? match[1] : null;
  }

  // Haversine distance in miles
  function haversine(lat1, lng1, lat2, lng2) {
    const R = 3959;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLng = (lng2 - lng1) * Math.PI / 180;
    const a = Math.sin(dLat/2) ** 2 + Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) * Math.sin(dLng/2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  // Geocode address via API route
  async function geocode(address) {
    const res = await fetch(`/api/geocode?address=${encodeURIComponent(address)}`);
    if (!res.ok) throw new Error('Could not geocode address');
    return await res.json();
  }

  // Get driving times via API route
  async function getDrivingTimes(origin, candidates) {
    const res = await fetch('/api/distance-matrix', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        originLat: origin.lat,
        originLng: origin.lng,
        destinations: candidates.map(r => ({ lat: r.lat, lng: r.lng })),
      }),
    });
    if (!res.ok) throw new Error('Distance calculation failed');
    const data = await res.json();
    return data.results.map(r => ({
      ...candidates[r.index],
      driveTime: r.durationSec,
      driveText: r.durationText,
      driveMiles: r.distanceMi,
    }));
  }

  // Build Google Flights URL from origin airport to destination airport
  function flightsUrl(fromCode, toCode) {
    return `https://www.google.com/travel/flights?q=flights+from+${fromCode}+to+${toCode}`;
  }

  // Major hub airports where most routes run direct.
  // Flights between two hubs assumed direct; anything else gets a layover allowance.
  const HUBS = new Set([
    'ATL','ORD','DFW','DEN','LAX','JFK','SFO','SEA','CLT','LAS','MIA','PHX',
    'EWR','MSP','DTW','BOS','PHL','IAH','IAD','SLC','MCO','BWI','DCA','LGA',
    'SAN','PDX','STL','MDW','TPA','MCI','IND','CLE','MEM','BNA','RDU','PIT',
    'DAL','OAK','AUS','SJC','SMF','HNL','YYZ','YVR','YUL','YYC',
  ]);

  // Estimate total travel time in hours (including layover when needed).
  // Formula:
  //   air time = great-circle miles / 500 mph
  //   + 1.0 hr fixed overhead (taxi, takeoff, descent, arrival taxi)
  //   + 2.0 hr layover if either endpoint is NOT a major hub (likely a connection)
  //   + 0.5 hr extra for very long hauls (>2500 mi)
  function estFlightHours(fromCode, toCode) {
    const a = AIRPORTS[fromCode];
    const b = AIRPORTS[toCode];
    if (!a || !b) return null;
    const miles = haversine(a.lat, a.lng, b.lat, b.lng);
    // Too close to fly — under ~150 mi is a drivable hop, not a flight (e.g. IAD↔BWI)
    if (miles < 150) return null;
    const airHours = miles / 500;
    const overhead = 1.0;
    const bothHubs = HUBS.has(fromCode) && HUBS.has(toCode);
    const layover = bothHubs ? 0 : 2.0;
    const longHaul = miles > 2500 ? 0.5 : 0;
    return airHours + overhead + layover + longHaul;
  }

  function formatHours(h) {
    if (h == null) return '—';
    const hrs = Math.floor(h);
    const mins = Math.round((h - hrs) * 60);
    return mins === 0 ? `${hrs}h` : `${hrs}h ${mins}m`;
  }

  // The Excel source stores airport-to-resort distance as drive time
  // (e.g. "2 hr", "1 hr 30 min"). Pass through verbatim with clearer labeling.
  function formatAirportDistance(val) {
    if (val == null || val === '' || val === '-') return null;
    const s = String(val).trim();
    if (!s) return null;
    return `${s} drive to resort`;
  }

  // Parse drive-time strings like "2 hr", "1 hr 30 min", "45 min" -> decimal hours.
  function parseDriveTimeHours(val) {
    if (val == null || val === '' || val === '-') return null;
    const s = String(val);
    const hrMatch = s.match(/(\d+(?:\.\d+)?)\s*hr/i);
    const minMatch = s.match(/(\d+)\s*min/i);
    if (!hrMatch && !minMatch) return null;
    const hrs = hrMatch ? parseFloat(hrMatch[1]) : 0;
    const mins = minMatch ? parseInt(minMatch[1], 10) : 0;
    return hrs + mins / 60;
  }

  // --- Mode toggle ---
  function setMode(mode) {
    currentMode = mode;
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    document.querySelector(`.mode-btn[data-mode="${mode}"]`).classList.add('active');

    const driveEls = document.querySelectorAll('.drive-only');
    const flyEls = document.querySelectorAll('.fly-only');
    const flyCols = document.querySelectorAll('.fly-col');

    if (mode === 'drive') {
      driveEls.forEach(el => el.style.display = '');
      flyEls.forEach(el => el.style.display = 'none');
      flyCols.forEach(el => el.style.display = 'none');
    } else {
      driveEls.forEach(el => el.style.display = 'none');
      flyEls.forEach(el => el.style.display = '');
      flyCols.forEach(el => el.style.display = '');
    }

    // Reset results when switching modes
    currentResults = [];
    renderTable();

    const statusBar = document.getElementById('statusBar');
    if (mode === 'drive') {
      statusBar.textContent = 'Enter your address and click Search to find resorts within driving distance.';
    } else {
      statusBar.textContent = 'Enter your home airport and click Search to see all resorts with flight links.';
    }
  }

  // --- Search ---
  async function search() {
    if (currentMode === 'drive') {
      await searchDrive();
    } else {
      searchFly();
    }
  }

  async function searchDrive() {
    const address = document.getElementById('address').value.trim();
    const maxHours = parseFloat(document.getElementById('maxDrive').value) || 8;

    if (!address) { alert('Please enter an address'); return; }

    const btn = document.getElementById('searchBtn');
    const loading = document.getElementById('loading');
    btn.disabled = true;
    loading.classList.add('active');
    document.getElementById('loadingText').textContent = 'Geocoding your address...';

    try {
      const origin = await geocode(address);

      const maxMiles = maxHours * 60;
      const candidates = RESORTS.filter(r =>
        r.lat && r.lng && haversine(origin.lat, origin.lng, r.lat, r.lng) < maxMiles * 1.5
      );

      document.getElementById('loadingText').textContent =
        `Found ${candidates.length} candidates, calculating driving distances...`;

      if (candidates.length === 0) {
        currentResults = [];
        renderTable();
        document.getElementById('statusBar').textContent = 'No resorts found within range.';
        return;
      }

      const driveResults = await getDrivingTimes(origin, candidates);

      const maxSec = maxHours * 3600;
      currentResults = driveResults.filter(r => r.driveTime <= maxSec);

      // Expose driveTime in hours as travelTime for unified sorting
      currentResults.forEach(r => { r.travelTime = r.driveTime / 3600; });

      sortCol = 'acreage';
      sortAsc = true;
      renderTable();

      const passCount = {};
      currentResults.forEach(r => { passCount[r.pass_type] = (passCount[r.pass_type] || 0) + 1; });
      const passSummary = Object.entries(passCount).map(([k, v]) => `${v} ${k}`).join(', ');
      document.getElementById('statusBar').textContent =
        `${currentResults.length} resorts within ${maxHours} hours: ${passSummary}`;

    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      btn.disabled = false;
      loading.classList.remove('active');
    }
  }

  function getHomeAirport() {
    const raw = document.getElementById('homeAirport').value.trim().toUpperCase();
    // Extract 3-letter code if user selected a datalist option or typed extra text
    const match = raw.match(/^([A-Z]{3})/);
    return match ? match[1] : raw;
  }

  function searchFly() {
    const homeAirport = getHomeAirport();
    if (!homeAirport) { alert('Please enter your home airport code'); return; }
    if (!AIRPORTS[homeAirport]) {
      alert(`Unknown airport code "${homeAirport}". Try a 3-letter IATA code (e.g. DEN, BOS, SLC).`);
      return;
    }
    const maxHours = parseFloat(document.getElementById('maxFlight').value) || 6;

    const enriched = [];
    for (const r of RESORTS) {
      const closest = parseAirportCode(r.closest_airport);
      const major = parseAirportCode(r.major_airport);
      // Skip self-flights (home === destination)
      const closestValid = closest && closest !== homeAirport;
      const majorValid = major && major !== homeAirport && major !== closest;
      if (!closestValid && !majorValid) continue;
      const closestHrs = closestValid ? estFlightHours(homeAirport, closest) : null;
      const majorHrs = majorValid ? estFlightHours(homeAirport, major) : null;
      const closestDriveHrs = parseDriveTimeHours(r.closest_airport_distance);
      const majorDriveHrs = parseDriveTimeHours(r.major_airport_distance);

      const closestTotal = (closestHrs != null && closestDriveHrs != null)
        ? closestHrs + closestDriveHrs : null;
      const majorTotal = (majorHrs != null && majorDriveHrs != null)
        ? majorHrs + majorDriveHrs : null;

      // Flight-only filter still uses flight hours (not drive time) so max-flight makes sense
      const flightCandidates = [closestHrs, majorHrs].filter(h => h != null);
      if (flightCandidates.length === 0) continue;
      const anyFits = flightCandidates.some(h => h <= maxHours);
      if (!anyFits) continue;

      // Pick the best airport option for the Travel Time cell.
      // Prefer the one with a known total; tie-break by shortest total.
      const totals = [
        { total: closestTotal, flight: closestHrs, drive: closestDriveHrs, code: closest, label: r.closest_airport },
        { total: majorTotal, flight: majorHrs, drive: majorDriveHrs, code: major, label: r.major_airport },
      ].filter(o => o.total != null);
      // Fallback: if no total (missing drive data), use flight-only
      const best = totals.length
        ? totals.reduce((a, b) => a.total < b.total ? a : b)
        : (closestHrs != null
            ? { total: null, flight: closestHrs, drive: null, code: closest, label: r.closest_airport }
            : { total: null, flight: majorHrs, drive: null, code: major, label: r.major_airport });

      enriched.push({
        ...r,
        closestFlightHrs: closestHrs,
        majorFlightHrs: majorHrs,
        travelTime: best.total != null ? best.total : best.flight,
        bestAirportCode: best.code,
        bestAirportLabel: best.label,
        bestFlightHrs: best.flight,
        bestDriveHrs: best.drive,
      });
    }
    currentResults = enriched;

    sortCol = 'acreage';
    sortAsc = true;
    renderTable();

    const passCount = {};
    currentResults.forEach(r => { passCount[r.pass_type] = (passCount[r.pass_type] || 0) + 1; });
    const passSummary = Object.entries(passCount).map(([k, v]) => `${v} ${k}`).join(', ');
    document.getElementById('statusBar').textContent = currentResults.length === 0
      ? `No resorts within ${maxHours}h flight of ${homeAirport}.`
      : `${currentResults.length} resorts within ${maxHours}h flight of ${homeAirport}: ${passSummary}`;
  }

  // --- Filters ---
  function toggleFilter(chip) {
    const filterType = chip.dataset.filter;
    document.querySelectorAll(`.filter-chip[data-filter="${filterType}"]`).forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    activeFilters[filterType] = chip.dataset.value;
    renderTable();
  }

  function getFilteredResults() {
    return currentResults.filter(r => {
      if (activeFilters.pass !== 'all' && r.pass_type !== activeFilters.pass) return false;
      if (activeFilters.daycare === 'yes') {
        const dc = (r.daycare || '').toLowerCase();
        if (!dc.startsWith('yes')) return false;
      }
      if (activeFilters.kidsfree === 'yes') {
        const kf = (r.kids_ski_free || '').toLowerCase();
        if (kf === 'no' || !kf) return false;
      }
      return true;
    });
  }

  // --- Sorting ---
  function sortTable(col) {
    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = true; }
    renderTable();
  }

  function getSortVal(r, col) {
    switch(col) {
      case 'travelTime': return r.travelTime != null ? r.travelTime : 999999;
      case 'pass': return r.pass_type || '';
      case 'name': return r.name || '';
      case 'location': return r.location || '';
      case 'acreage': return r.acreage || 0;
      case 'kids_ski_free': return r.kids_ski_free || '';
      case 'ski_school_min_age': return r.ski_school_min_age || 99;
      default: return '';
    }
  }

  // --- Render ---
  function renderTable() {
    const filtered = getFilteredResults();
    const isDrive = currentMode === 'drive';
    const isFly = currentMode === 'fly';
    const homeAirport = getHomeAirport();

    filtered.sort((a, b) => {
      let va = getSortVal(a, sortCol), vb = getSortVal(b, sortCol);
      if (typeof va === 'string') { va = va.toLowerCase(); vb = vb.toLowerCase(); }
      if (sortCol === 'acreage') return sortAsc ? vb - va : va - vb;
      if (va < vb) return sortAsc ? -1 : 1;
      if (va > vb) return sortAsc ? 1 : -1;
      return 0;
    });

    const tbody = document.getElementById('resortBody');
    const empty = document.getElementById('emptyState');

    // Fly-only elements (footnote only now — the Travel Time column is shown in both modes)
    document.querySelectorAll('.fly-col').forEach(el => el.style.display = isFly ? '' : 'none');

    // Update sort indicators on column headers
    // For acreage, asc=true means biggest-first (reversed in comparator), so flip the arrow.
    const arrowUp = '&#9650;';   // ▲
    const arrowDown = '&#9660;'; // ▼
    const effectiveAsc = sortCol === 'acreage' ? !sortAsc : sortAsc;
    document.querySelectorAll('thead th[data-col]').forEach(th => {
      const arrow = th.querySelector('.sort-arrow');
      if (th.dataset.col === sortCol) {
        th.classList.add('sorted');
        if (arrow) arrow.innerHTML = effectiveAsc ? arrowUp : arrowDown;
      } else {
        th.classList.remove('sorted');
        if (arrow) arrow.innerHTML = arrowDown;
      }
    });

    if (filtered.length === 0) {
      tbody.innerHTML = '';
      empty.style.display = 'block';
      if (currentResults.length === 0) {
        empty.textContent = isDrive
          ? 'Enter your address above to find resorts within driving distance.'
          : 'Enter your home airport and click Search.';
      } else {
        empty.textContent = 'No resorts match your current filters.';
      }
      return;
    }

    empty.style.display = 'none';

    tbody.innerHTML = filtered.map(r => {
      // Unified Travel Time cell
      let travelCell = '';
      if (isDrive) {
        const driveHrs = r.driveTime / 3600;
        const cls = driveHrs <= 4 ? 'short' : driveHrs <= 6 ? 'medium' : 'long';
        travelCell = `<td><span class="drive-time ${cls}">${r.driveText}</span></td>`;
      } else {
        const total = r.travelTime;
        const cls = total == null ? 'long' : total <= 5 ? 'short' : total <= 8 ? 'medium' : 'long';
        const totalStr = total != null ? formatHours(total) : '—';
        const via = r.bestAirportCode ? ` via ${r.bestAirportCode}` : '';
        const parts = [];
        if (r.bestFlightHrs != null) parts.push(`${formatHours(r.bestFlightHrs)} flight`);
        if (r.bestDriveHrs != null) parts.push(`${formatHours(r.bestDriveHrs)} drive`);
        const breakdown = parts.length ? `<br><span class="pass-count">${parts.join(' + ')}${via}</span>` : '';
        travelCell = `<td><span class="drive-time ${cls}">${totalStr}</span>${breakdown}</td>`;
      }

      // Resort name with link
      const resortName = r.url
        ? `<a href="${r.url}" target="_blank">${r.name}</a>`
        : r.name;

      // Kids ski free with link
      const kidsFreeBadge = r.kids_ski_free
        ? `<span class="badge ${r.kids_ski_free === 'No' ? 'badge-no' : 'badge-yes'}">${r.kids_ski_free}</span>`
        : '-';
      const kidsFree = r.kids_ski_free && r.kids_ski_free_url
        ? `<a href="${r.kids_ski_free_url}" target="_blank">${kidsFreeBadge}</a>`
        : kidsFreeBadge;

      // Ski school age with link
      const schoolAge = r.ski_school_min_age
        ? (r.ski_school_url
          ? `<a href="${r.ski_school_url}" target="_blank">${r.ski_school_min_age}</a>`
          : r.ski_school_min_age)
        : '-';

      // Ski school cost with link
      const schoolCost = r.ski_school_max_cost
        ? (r.ski_school_cost_url
          ? `<a href="${r.ski_school_cost_url}" target="_blank">$${r.ski_school_max_cost}</a>`
          : '$' + r.ski_school_max_cost)
        : '-';

      // Daycare with link; add Baby Club Med line for Club Med resorts
      const daycareBadge = r.daycare
        ? `<span class="badge ${r.daycare.toLowerCase().startsWith('yes') ? 'badge-yes' : 'badge-no'}">${r.daycare}</span>`
        : '-';
      let daycare = r.daycare && r.daycare_url
        ? `<a href="${r.daycare_url}" target="_blank">${daycareBadge}</a>`
        : daycareBadge;
      if (r.pass_type === 'Club Med' && r.baby_club_med) {
        const bcm = String(r.baby_club_med);
        const bcmBadge = `<span class="badge ${bcm.toLowerCase().startsWith('yes') ? 'badge-yes' : 'badge-no'}">Baby Club Med: ${bcm}</span>`;
        daycare += `<br>${bcmBadge}`;
      }

      // Airport + flight cells (split into Local and Major)
      const airportCode = parseAirportCode(r.closest_airport);
      const majorCode = parseAirportCode(r.major_airport);

      // Major row should only render when it differs from the local airport
      const showMajor = majorCode && majorCode !== airportCode;

      const makeFlightBadge = (code, hrs) => {
        if (!code) return '-';
        // Suppress self-flights
        if (isFly && homeAirport && code === homeAirport) return '-';
        const url = isFly && homeAirport ? flightsUrl(homeAirport, code) : flightsUrl('', code);
        const prefix = isFly && homeAirport ? `${homeAirport}→${code}` : code;
        const timeStr = isFly && hrs != null ? ` ~${formatHours(hrs)}` : '';
        return `<a href="${url}" target="_blank" class="badge badge-flight">&#9992; ${prefix}${timeStr}</a>`;
      };

      const combineAirport = (label, code, hrs) => {
        if (!code) return '-';
        const badge = makeFlightBadge(code, hrs);
        const badgeLine = badge && badge !== '-' ? `<br>${badge}` : '';
        return `${label}${badgeLine}`;
      };
      const localAirportCell = combineAirport(r.closest_airport, airportCode, r.closestFlightHrs);
      const majorAirportCell = showMajor
        ? combineAirport(r.major_airport, majorCode, r.majorFlightHrs)
        : '-';

      return `<tr>
        ${travelCell}
        <td><span class="badge badge-pass">${r.pass_type}</span></td>
        <td>${resortName}</td>
        <td>${r.location || ''}</td>
        <td>${r.acreage ? r.acreage.toLocaleString() : '-'}</td>
        <td>${kidsFree}</td>
        <td>${schoolAge}</td>
        <td>${schoolCost}</td>
        <td>${daycare}</td>
        <td>${localAirportCell}</td>
        <td>${majorAirportCell}</td>
      </tr>`;
    }).join('');
  }

  // Wire up event listeners
  document.getElementById('searchBtn').addEventListener('click', search);
  document.getElementById('address').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') search();
  });
  document.getElementById('homeAirport').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') search();
  });
  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', () => toggleFilter(chip));
  });
  document.querySelectorAll('thead th[data-col]').forEach(th => {
    th.addEventListener('click', () => sortTable(th.dataset.col));
  });
  document.getElementById('modeDrive').addEventListener('click', () => setMode('drive'));
  document.getElementById('modeFly').addEventListener('click', () => setMode('fly'));

  // Places Autocomplete disabled — Google's legacy Places API is deprecated and currently
  // returns ApiNotActivatedMapError. See memory "powderhunter Places Autocomplete broken".
  // Users type the full address manually for now.

</script>

</body>
</html>
